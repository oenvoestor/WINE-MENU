import { wineTypes, regions, cities } from "@/data/restaurants";
import { ChevronDown } from "lucide-react";

interface FilterBarProps {
  selectedType: string;
  selectedRegion: string;
  selectedCity: string;
  onTypeChange: (type: string) => void;
  onRegionChange: (region: string) => void;
  onCityChange: (city: string) => void;
}

const typeEmoji: Record<string, string> = {
  Rouge: "🔴",
  Blanc: "⚪",
  Rosé: "🩷",
  Champagne: "🥂",
  Pétillant: "✨",
  Orange: "🟠",
  Sucré: "🍯",
};

const FilterBar = ({
  selectedType,
  selectedRegion,
  selectedCity,
  onTypeChange,
  onRegionChange,
  onCityChange,
}: FilterBarProps) => {
  return (
    <div className="sticky top-0 z-20 border-b border-border bg-background/95 backdrop-blur-sm">
      <div className="container mx-auto px-4 py-3">
        <div className="flex flex-wrap items-center gap-2">
          <button
            onClick={() => onTypeChange("")}
            className={`rounded-full px-4 py-2 text-sm font-body font-medium transition-all duration-200 ${
              selectedType === ""
                ? "bg-foreground text-background"
                : "border border-border bg-transparent text-foreground hover:bg-secondary"
            }`}
          >
            Tous
          </button>

          {wineTypes.map((type) => (
            <button
              key={type}
              onClick={() => onTypeChange(type === selectedType ? "" : type)}
              className={`rounded-full px-4 py-2 text-sm font-body font-medium transition-all duration-200 ${
                selectedType === type
                  ? "bg-foreground text-background"
                  : "border border-border bg-transparent text-foreground hover:bg-secondary"
              }`}
            >
              <span className="mr-1.5">{typeEmoji[type]}</span>
              {type}
            </button>
          ))}

          <div className="mx-1 hidden h-5 w-px bg-border md:block" />

          <div className="relative">
            <select
              value={selectedRegion}
              onChange={(e) => onRegionChange(e.target.value)}
              className="cursor-pointer appearance-none rounded-full border border-border bg-transparent py-2 pl-3 pr-8 text-sm font-body font-medium text-foreground transition-all hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-accent/30"
            >
              <option value="">Région</option>
              {regions.map((region) => (
                <option key={region} value={region}>
                  {region}
                </option>
              ))}
            </select>
            <ChevronDown className="pointer-events-none absolute right-2.5 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-muted-foreground" />
          </div>

          <div className="relative">
            <select
              value={selectedCity}
              onChange={(e) => onCityChange(e.target.value)}
              className="cursor-pointer appearance-none rounded-full border border-border bg-transparent py-2 pl-3 pr-8 text-sm font-body font-medium text-foreground transition-all hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-accent/30"
            >
              <option value="">Ville</option>
              {cities.map((city) => (
                <option key={city} value={city}>
                  {city}
                </option>
              ))}
            </select>
            <ChevronDown className="pointer-events-none absolute right-2.5 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-muted-foreground" />
          </div>
        </div>
      </div>
    </div>
  );
};

export default FilterBar;

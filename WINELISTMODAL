import { X, MapPin, FileDown } from "lucide-react";
import { Link } from "react-router-dom";
import type { Restaurant, Wine } from "@/data/restaurants";

interface WineListModalProps {
  restaurant: Restaurant | null;
  onClose: () => void;
}

const typeLabel: Record<string, string> = {
  Rouge: "Rouges",
  Blanc: "Blancs",
  Rosé: "Rosés",
  Champagne: "Champagnes",
  Pétillant: "Pétillants",
  Orange: "Oranges",
  Sucré: "Vins sucrés",
};

const WineRow = ({ wine, onClose }: { wine: Wine; onClose: () => void }) => (
  <div className="flex items-start justify-between border-b border-border/50 py-3 last:border-0">
    <div className="min-w-0 flex-1 pr-4">
      <Link
        to={`/vin/${wine.id}`}
        onClick={onClose}
        className="font-body text-sm font-medium leading-snug text-foreground underline-offset-2 transition-colors hover:text-accent hover:underline"
      >
        {wine.name}
      </Link>

      <div className="mt-0.5 flex items-center gap-2">
        <span className="text-xs font-body text-muted-foreground">{wine.year}</span>
        <span className="text-muted-foreground/30">·</span>
        <span className="text-xs font-body text-muted-foreground">{wine.appellation}</span>
      </div>

      {wine.description && (
        <p className="mt-0.5 font-body text-xs italic text-muted-foreground/70">
          {wine.description}
        </p>
      )}
    </div>

    <span className="whitespace-nowrap font-display text-sm font-semibold tabular-nums text-foreground">
      {wine.price < 100 ? `${wine.price}€` : `${wine.price.toLocaleString("fr-FR")} €`}
    </span>
  </div>
);

const WineListModal = ({ restaurant, onClose }: WineListModalProps) => {
  if (!restaurant) return null;

  const grouped = restaurant.wines.reduce<Record<string, Wine[]>>((acc, wine) => {
    (acc[wine.type] = acc[wine.type] || []).push(wine);
    return acc;
  }, {});

  return (
    <div className="fixed inset-0 z-50 flex items-start justify-center px-4 pb-6 pt-6">
      <div
        className="absolute inset-0 bg-foreground/60 backdrop-blur-sm"
        onClick={onClose}
      />

      <div className="relative max-h-[92vh] w-full max-w-xl overflow-y-auto rounded-2xl bg-card shadow-2xl animate-fade-in">
        <div className="sticky top-0 z-10 flex items-start justify-between rounded-t-2xl border-b border-border bg-card px-6 py-5">
          <div>
            <h2 className="font-display text-2xl font-bold text-foreground">
              {restaurant.name}
            </h2>

            <div className="mt-1 flex items-center gap-2 text-muted-foreground">
              <MapPin className="h-3.5 w-3.5" />
              <span className="text-sm font-body">{restaurant.city}</span>
              <span className="text-muted-foreground/30">·</span>
              <span className="text-sm font-body">{restaurant.cuisine}</span>
              <span className="text-muted-foreground/30">·</span>
              <span className="text-sm font-body">{restaurant.wineCount} vins</span>
            </div>
          </div>

          <button
            onClick={onClose}
            className="-mr-2 -mt-1 rounded-full p-2 transition-colors hover:bg-secondary"
            aria-label="Fermer"
          >
            <X className="h-5 w-5 text-foreground" />
          </button>
        </div>

        {restaurant.pdfUrls && restaurant.pdfUrls.length > 0 && (
          <div className="px-6 pb-2 pt-4">
            <div className="flex flex-wrap gap-2">
              {restaurant.pdfUrls.map((url, i) => (
                <a
                  key={url}
                  href={url}
                  target="_blank"
                  rel="noopener noreferrer"
                  className="inline-flex items-center gap-2 rounded-lg bg-foreground px-4 py-2.5 font-body text-sm font-medium text-background transition-colors hover:bg-foreground/90"
                >
                  <FileDown className="h-4 w-4" />
                  {restaurant.pdfUrls!.length > 1
                    ? `Carte complète (${i + 1}/${restaurant.pdfUrls!.length})`
                    : "Voir la carte complète (PDF)"}
                </a>
              ))}
            </div>

            <p className="mt-2 font-body text-xs text-muted-foreground">
              Carte disponible en PDF · {restaurant.wineCount}+ références
            </p>
          </div>
        )}

        <div className="px-6 py-4">
          <h3 className="mb-4 font-display text-xs font-semibold uppercase tracking-[0.15em] text-muted-foreground">
            Sélection
          </h3>

          {Object.entries(grouped).map(([type, wines]) => (
            <div key={type} className="mb-6 last:mb-2">
              <h3 className="mb-3 font-display text-xs font-semibold uppercase tracking-[0.15em] text-accent">
                {typeLabel[type] || type}
              </h3>

              {wines.map((wine) => (
                <WineRow key={wine.id} wine={wine} onClose={onClose} />
              ))}
            </div>
          ))}
        </div>
      </div>
    </div>
  );
};

export default WineListModal;

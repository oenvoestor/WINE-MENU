export type Wine = {
  id: string;
  name: string;
  year: number | string;
  type: "Rouge" | "Blanc" | "Rosé" | "Champagne" | "Pétillant" | "Orange" | "Sucré";
  region: string;
  appellation: string;
  price: number;
  producer?: string;
  description?: string;
};

export type Restaurant = {
  id: string;
  slug: string;
  name: string;
  city: string;
  cuisine: string;
  rating: number;
  image: string;
  wineCount: number;
  wines: Wine[];
  pdfUrls?: string[];
  address?: string;
  phone?: string;
  website?: string;
  hours?: string;
  reservationUrl?: string;
};

